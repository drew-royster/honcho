# Compose project paths
HONCHO_SOURCE_DIR=/mnt/user/appdata/honcho/source
HONCHO_CODEX_DIR=/mnt/user/appdata/honcho/codex
HONCHO_STATE_DIR=/mnt/user/appdata/honcho/state
HONCHO_EMBEDDINGS_CACHE=/mnt/user/appdata/honcho/ollama

# Host port for the Honcho API
HONCHO_API_PORT=8787

# Local embeddings sidecar
HONCHO_EMBEDDINGS_PORT=11434
HONCHO_EMBEDDINGS_MODEL=qwen3-embedding:0.6b
HONCHO_EMBEDDINGS_API_KEY=ollama

# App settings
LOG_LEVEL=INFO
AUTH_USE_AUTH=false
CACHE_ENABLED=false
DERIVER_FLUSH_ENABLED=true
EMBED_MESSAGES=true
VECTOR_STORE_TYPE=sqlite_vec
VECTOR_STORE_DIMENSIONS=1024
VECTOR_STORE_SQLITE_PATH=/data/honcho.db

# Codex-backed OpenAI transport
LLM_OPENAI_USE_CODEX_AUTH=true
LLM_OPENAI_CODEX_AUTH_FILE=/config/codex/auth.json
LLM_OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api/codex

# OpenAI-compatible local embeddings
LLM_EMBEDDING_PROVIDER=openai_compatible
LLM_EMBEDDING_MODEL=qwen3-embedding:0.6b
LLM_EMBEDDING_API_KEY=ollama
LLM_EMBEDDING_BASE_URL=http://embeddings:11434/v1

# OpenAI/Codex defaults for active LLM subsystems
SUMMARY_PROVIDER=openai
SUMMARY_MODEL=gpt-5.4

DERIVER_ENABLED=true
DERIVER_PROVIDER=openai
DERIVER_MODEL=gpt-5.4

PEER_CARD_ENABLED=true

DREAM_ENABLED=false
DREAM_PROVIDER=openai
DREAM_MODEL=gpt-5.4
DREAM_DEDUCTION_MODEL=gpt-5.4
DREAM_INDUCTION_MODEL=gpt-5.4

# Dialectic levels need full objects when configured via env
DIALECTIC__LEVELS__MINIMAL__PROVIDER=openai
DIALECTIC__LEVELS__MINIMAL__MODEL=gpt-5.4
DIALECTIC__LEVELS__MINIMAL__THINKING_BUDGET_TOKENS=0
DIALECTIC__LEVELS__MINIMAL__MAX_TOOL_ITERATIONS=1
DIALECTIC__LEVELS__MINIMAL__MAX_OUTPUT_TOKENS=250
DIALECTIC__LEVELS__MINIMAL__TOOL_CHOICE=any

DIALECTIC__LEVELS__LOW__PROVIDER=openai
DIALECTIC__LEVELS__LOW__MODEL=gpt-5.4
DIALECTIC__LEVELS__LOW__THINKING_BUDGET_TOKENS=0
DIALECTIC__LEVELS__LOW__MAX_TOOL_ITERATIONS=5
DIALECTIC__LEVELS__LOW__TOOL_CHOICE=any

DIALECTIC__LEVELS__MEDIUM__PROVIDER=openai
DIALECTIC__LEVELS__MEDIUM__MODEL=gpt-5.4
DIALECTIC__LEVELS__MEDIUM__THINKING_BUDGET_TOKENS=1024
DIALECTIC__LEVELS__MEDIUM__MAX_TOOL_ITERATIONS=2

DIALECTIC__LEVELS__HIGH__PROVIDER=openai
DIALECTIC__LEVELS__HIGH__MODEL=gpt-5.4
DIALECTIC__LEVELS__HIGH__THINKING_BUDGET_TOKENS=1024
DIALECTIC__LEVELS__HIGH__MAX_TOOL_ITERATIONS=4

DIALECTIC__LEVELS__MAX__PROVIDER=openai
DIALECTIC__LEVELS__MAX__MODEL=gpt-5.4
DIALECTIC__LEVELS__MAX__THINKING_BUDGET_TOKENS=2048
DIALECTIC__LEVELS__MAX__MAX_TOOL_ITERATIONS=10
